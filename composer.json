{
    "name": "php-blog-cms/blog",
    "description": "Simple blog CMS on pure PHP with Smarty and MySQL",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "smarty/smarty": "^5.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
